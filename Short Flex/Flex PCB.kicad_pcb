				(thickness 0.01)
			)
			(layer "F.Cu"
				(type "copper")
				(thickness 0.035)
			)
			(layer "dielectric 1"
				(type "core")
				(color "Polyimide")
				(thickness 0.1)
				(material "Polyimide")
				(epsilon_r 3.2)
				(loss_tangent 0.004)
